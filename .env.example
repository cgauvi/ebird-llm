# eBird API key — obtain from https://ebird.org/api/keygen
EBIRD_API_KEY=your_ebird_api_key_here

# ---------------------------------------------------------------------------
# Application environment
# ---------------------------------------------------------------------------
# Controls dev-only features (e.g. the log pane in the sidebar).
# Set to "prod" to simulate production behaviour locally.
APP_ENV=dev

# ---------------------------------------------------------------------------
# HuggingFace
# ---------------------------------------------------------------------------
# Token:  https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Model to use.  Set to a short alias OR a full HuggingFace repo ID.
# If unset, the default is: qwen2.5-72b
#
# Available aliases (see src/config.py — MODELS for the full list):
#
#   qwen2.5-72b                    Qwen/Qwen2.5-72B-Instruct                        (default)
#   gemma-3-27b                    google/gemma-3-27b-it                            (*)
#
# (*) Requires accepting the model's licence on HuggingFace before use.
#
#HF_MODEL_ID=qwen2.5-72b
